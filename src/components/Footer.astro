---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="wrap footer-inner">
    <div class="left">
      <span class="eyebrow">Glasgow, Scotland</span>
    </div>
    <div class="right">
      <span class="meta">© {year} John Smith</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    margin-top: 80px;
    padding: 32px 0;
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .meta {
    font-size: 12px;
    color: var(--text-faint);
  }
</style>
