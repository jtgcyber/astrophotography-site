---
const links = [
  { href: '/', label: 'Index' },
  { href: '/gallery/', label: 'Gallery' },
  { href: '/equipment/', label: 'Equipment' },
  { href: '/about/', label: 'About' },
];

const current = Astro.url.pathname;
---

<header class="nav">
  <div class="wrap nav-inner">
    <a href="/" class="brand">
      <span class="brand-name">John Greig</span>
      <span class="brand-tag">Astrophotography</span>
    </a>
    <nav class="links" aria-label="Primary">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={['link', { active: current === l.href }]}
        >
          {l.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(10, 10, 12, 0.85);
    backdrop-filter: saturate(160%) blur(12px);
    -webkit-backdrop-filter: saturate(160%) blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 0;
  }
  .brand {
    display: flex;
    align-items: baseline;
    gap: 10px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .brand-tag {
    color: var(--text-faint);
    font-weight: 400;
  }
  .links {
    display: flex;
    gap: 28px;
  }
  .link {
    font-size: 13px;
    color: var(--text-muted);
    transition: color 0.2s ease;
    position: relative;
  }
  .link:hover { color: var(--text); }
  .link.active { color: var(--text); }
  .link.active::after {
    content: '';
    position: absolute;
    bottom: -22px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--text);
  }

  @media (max-width: 600px) {
    .brand-tag { display: none; }
    .links { gap: 18px; }
    .link { font-size: 12px; }
  }
</style>
