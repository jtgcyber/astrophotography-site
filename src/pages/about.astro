---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About — John Greig Astrophotography">
  <section class="wrap intro">
    <span class="eyebrow">About</span>
    <h1>About</h1>
  </section>

  <section class="wrap body">
    <p>
      I'm an amateur astrophotographer based in Glasgow, capturing deep-sky
      objects from a small back-garden setup and the occasional darker site
      when the weather and life cooperate.
    </p>
    <p>
      What keeps me coming back is the simple fact that most of the light
      hitting the sensor left its source tens to millions of years ago. There's
      something grounding about sitting out for hours and letting the
      universe slowly reveal itself, one frame at a time.
    </p>
    <p>
      Feel free to follow me on <a href="https://instagram.com/jgshootsspace" class="link">Instagram</a>.
        </p>
  </section>
</Layout>

<style>
  .intro {
    padding: 80px 0 40px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 56px;
  }
  .intro h1 { margin-top: 12px; }
  .body {
    max-width: 64ch;
    display: flex;
    flex-direction: column;
    gap: 20px;
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-muted);
  }
  .body p { margin: 0; }
  .link {
    color: var(--text);
    border-bottom: 1px solid var(--border-strong);
    transition: border-color 0.2s ease;
  }
  .link:hover { border-color: var(--text); }
</style>
