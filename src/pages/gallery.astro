---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PhotoCard from '../components/PhotoCard.astro';

const photos = (await getCollection('photos')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Layout title="Gallery — John Greig Astrophotography">
  <section class="wrap intro">
    <span class="eyebrow">Gallery</span>
    <h1>Every capture</h1>
    <p class="lead">
      Astrophotography from Scotland — deep-sky, lunar, and wide-field
      captures. Click any image for full details and acquisition notes.
    </p>
  </section>

  <section class="wrap">
    <div class="grid">
      {photos.map((p) => <PhotoCard photo={p} />)}
    </div>
  </section>
</Layout>

<style>
  .intro {
    padding: 80px 0 56px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 56px;
  }
  .intro h1 {
    margin: 12px 0 18px;
  }
  .lead {
    max-width: 60ch;
    color: var(--text-muted);
    font-size: 16px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 40px 24px;
  }
</style>
